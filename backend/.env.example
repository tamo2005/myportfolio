# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ========== SERVER CONFIGURATION ==========
# Server port
PORT=5000

# Environment mode (development, production, test)
NODE_ENV=development

# ========== DATABASE CONFIGURATION ==========
# MongoDB connection URI
# Local: mongodb://localhost:27017/portfolio
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/portfolio
MONGO_URI=mongodb://localhost:27017/portfolio

# ========== FRONTEND CONFIGURATION ==========
# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000

# ========== OPTIONAL: FUTURE FEATURES ==========
# Email configuration (for sending responses to messages)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# JWT Secret (for future authentication implementation)
# JWT_SECRET=your_super_secret_jwt_key_here

# API Rate Limiting (for future implementation)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
